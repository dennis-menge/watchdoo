# Watchdoo Backend

# Cookidoo credentials
COOKIDOO_EMAIL=your@email.com
COOKIDOO_PASSWORD=your-password

# Cookidoo localization
COOKIDOO_COUNTRY=de
COOKIDOO_LANGUAGE=de-DE

# API key for Watch <-> Backend auth (generate with: openssl rand -hex 32)
API_KEY=change-me-to-a-random-string

# Logging
LOG_LEVEL=INFO
